<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="GUI.BattleController"
            prefWidth="1100" prefHeight="900"
            style="-fx-background-color: #2b2b2b;">

    <VBox spacing="15" alignment="CENTER" AnchorPane.topAnchor="15"
          AnchorPane.leftAnchor="15" AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

        <!-- Title -->
        <Label style="-fx-font-size: 32px; -fx-text-fill: gold; -fx-font-weight: bold;"
               text="⚔️ PvP Battle Arena ⚔️">
            <font>
                <Font name="System Bold" size="32" />
            </font>
        </Label>

        <!-- Battle Arena - Two Parties Side by Side -->
        <HBox spacing="40" alignment="CENTER">
            <!-- Your Party (Left Side) -->
            <VBox spacing="15" alignment="CENTER"
                  style="-fx-background-color: #3c3f41; -fx-padding: 20; -fx-background-radius: 15;">

                <HBox spacing="10" alignment="CENTER">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: lightgreen;" text="🛡️" />
                    <Label style="-fx-font-size: 20px; -fx-text-fill: lightgreen; -fx-font-weight: bold;"
                           fx:id="yourPartyNameLabel" text="Your Party" />
                </HBox>

                <ListView fx:id="yourPartyList" prefWidth="300" prefHeight="280"
                          style="-fx-background-color: #2b2b2b; -fx-control-inner-background: #2b2b2b; -fx-text-fill: white; -fx-font-size: 13px;"/>

                <Label style="-fx-text-fill: lightgray; -fx-font-size: 14px;"
                       fx:id="yourPartyStatus" text="5/5 heroes standing" />
            </VBox>

            <!-- VS Divider -->
            <VBox alignment="CENTER" spacing="10">
                <Label style="-fx-font-size: 48px; -fx-text-fill: red; -fx-font-weight: bold;" text="⚔️" />
                <Label style="-fx-font-size: 28px; -fx-text-fill: yellow; -fx-font-weight: bold;" text="VS" />
                <Label style="-fx-font-size: 48px; -fx-text-fill: red; -fx-font-weight: bold;" text="⚔️" />
            </VBox>

            <!-- Opponent Party (Right Side) -->
            <VBox spacing="15" alignment="CENTER"
                  style="-fx-background-color: #3c3f41; -fx-padding: 20; -fx-background-radius: 15;">

                <HBox spacing="10" alignment="CENTER">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: pink;" text="👾" />
                    <Label style="-fx-font-size: 20px; -fx-text-fill: pink; -fx-font-weight: bold;"
                           fx:id="opponentPartyNameLabel" text="Opponent Party" />
                </HBox>

                <ListView fx:id="opponentPartyList" prefWidth="300" prefHeight="280"
                          style="-fx-background-color: #2b2b2b; -fx-control-inner-background: #2b2b2b; -fx-text-fill: white; -fx-font-size: 13px;"/>

                <Label style="-fx-text-fill: lightgray; -fx-font-size: 14px;"
                       fx:id="opponentPartyStatus" text="5/5 heroes standing" />
            </VBox>
        </HBox>

        <!-- Battle Log Section -->
        <VBox spacing="8" alignment="CENTER_LEFT"
              style="-fx-background-color: #1e1e1e; -fx-padding: 12; -fx-background-radius: 10;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label style="-fx-font-size: 18px; -fx-text-fill: cyan; -fx-font-weight: bold;" text="📜 Battle Log" />
                <Label style="-fx-text-fill: gray; -fx-font-size: 11px;" text="(Actions appear here)" />
            </HBox>

            <TextArea fx:id="battleLogArea" prefRowCount="5" prefWidth="1000"
                      editable="false" wrapText="true"
                      style="-fx-font-family: monospace; -fx-control-inner-background: #1e1e1e; -fx-text-fill: #e0e0e0; -fx-font-size: 13px;"/>
        </VBox>

        <!-- TEST BUTTON - Add this temporarily -->
        <Button text="ACTIONS" onAction="#testShowButtons"
                prefWidth="200" prefHeight="40"
                style="-fx-font-size: 16px; -fx-background-color: purple; -fx-text-fill: white;"/>

        <!-- ACTION BUTTONS - These should appear when it's a hero's turn -->
        <VBox fx:id="actionButtonsVBox" spacing="15" alignment="CENTER"
              style="-fx-background-color: #333333; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: gold; -fx-border-width: 3; -fx-border-radius: 15;"
              visible="false" managed="false">

            <Label style="-fx-font-size: 20px; -fx-text-fill: gold; -fx-font-weight: bold;"
                   text="⚔️ CHOOSE YOUR ACTION ⚔️" />

            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="attackButton" text="⚔️ ATTACK"
                        onAction="#attackAction" prefWidth="130" prefHeight="50"
                        style="-fx-font-size: 16px; -fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;"/>

                <Button fx:id="defendButton" text="🛡️ DEFEND"
                        onAction="#defendAction" prefWidth="130" prefHeight="50"
                        style="-fx-font-size: 16px; -fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;"/>


                <Button fx:id="castButton" text="💫 CAST"
                        onAction="#castAction" prefWidth="130" prefHeight="50"
                        style="-fx-font-size: 16px; -fx-background-color: #7b1fa2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;"/>
            </HBox>

            <HBox spacing="20" alignment="CENTER">
                <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="Select Target:" />
                <ComboBox fx:id="targetSelector" prefWidth="250"
                          style="-fx-background-color: #444; -fx-text-fill: white; -fx-font-size: 14px;"/>
            </HBox>

            <Label style="-fx-text-fill: #aaa; -fx-font-size: 12px;"
                   text="Choose an action above. For Attack and Cast, select a target first." />
        </VBox>

        <!-- Turn Indicator -->
        <HBox spacing="10" alignment="CENTER"
              style="-fx-background-color: #333333; -fx-padding: 10; -fx-background-radius: 20;">
            <Label style="-fx-font-size: 18px; -fx-text-fill: orange; -fx-font-weight: bold;" text="🎮 Current Turn:" />
            <Label fx:id="turnIndicator" style="-fx-font-size: 18px; -fx-text-fill: yellow; -fx-font-weight: bold;"
                   text="Click 'Start Battle' to begin" />
        </HBox>

        <!-- Battle Controls -->
        <HBox spacing="30" alignment="CENTER" style="-fx-padding: 10;">
            <Button fx:id="startBattleButton" text="⚔️ START BATTLE"
                    onAction="#startBattle" prefWidth="200" prefHeight="50"
                    style="-fx-font-size: 18px; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;">
                <font><Font name="System Bold" size="18" /></font>
            </Button>

            <Button fx:id="nextTurnButton" text="⏭️ NEXT TURN"
                    onAction="#nextTurn" prefWidth="200" prefHeight="50"
                    style="-fx-font-size: 18px; -fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;"
                    disable="true">
                <font><Font name="System Bold" size="18" /></font>
            </Button>

            <Button fx:id="backButton" text="🔙 BACK TO MENU"
                    onAction="#backToMainMenu" prefWidth="200" prefHeight="50"
                    style="-fx-font-size: 18px; -fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;">
                <font><Font name="System Bold" size="18" /></font>
            </Button>
        </HBox>

        <!-- Instruction Label -->
        <Label style="-fx-text-fill: #888888; -fx-font-size: 14px;"
               text="1. Click START BATTLE | 2. ACTION BUTTONS will appear | 3. Choose Attack/Defend/Wait/Cast | 4. Select target for attacks/spells | 5. Watch battle unfold!" />
    </VBox>
</AnchorPane>