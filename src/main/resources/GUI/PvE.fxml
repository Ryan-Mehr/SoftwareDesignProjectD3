<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400" prefWidth="600" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Classes.PvE.PvEController">

   <padding>
      <Insets bottom="10" left="10" right="10" top="10" />
   </padding>
   <Label fx:id="roomLabel" text="Room 1: Zombie" />

   <!-- Player Health -->
   <HBox spacing="10">
      <Label text="Player Health:" />
      <Label fx:id="playerHealthLabel" text="100" />
   </HBox>

   <!-- Enemy Health -->
   <HBox spacing="10">
      <Label text="Enemy Health:" />
      <Label fx:id="enemyHealthLabel" text="100" />
   </HBox>

   <!-- Player Action Buttons -->
   <HBox spacing="10">
      <Button fx:id="attackButton" onAction="#handleAttack" text="Attack" />
      <Button fx:id="defendButton" onAction="#handleDefend" text="Defend" />
      <Button fx:id="startButton" onAction="#handleStartBattle" text="Start Battle" />
      <Button fx:id="nextRoomButton" disable="true" mnemonicParsing="false" onAction="#handleNextRoom" text="Next Room" />
   </HBox>

   <!-- Battle Log -->
   <TextArea fx:id="battleLog" editable="false" prefHeight="250" wrapText="true" />
   <HBox prefHeight="35.0" prefWidth="580.0" spacing="25.0">
      <children>
         <Button mnemonicParsing="false" onAction="#saveTheCampaign" text="Save " />
         <Button mnemonicParsing="false" onAction="#backToMainMenu" text="Back to Main Menu" />
      </children>
   </HBox>

</VBox>
